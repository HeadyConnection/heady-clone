# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Heady™ AI Platform — Environment Variables Reference               ║
# ║  Copy this file to .env and fill in your values.                    ║
# ║  NEVER commit .env to version control.                              ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3301
HEADY_PORT=3301
HEADY_HOST=0.0.0.0
HEADY_NODE_NAME=heady-primary
LOG_LEVEL=info
LOG_FORMAT=pretty

# ─── Authentication ───────────────────────────────────────────────────────────
HEADY_API_KEY=your-internal-api-key-here
ADMIN_TOKEN=your-admin-token-here
JWT_SECRET=your-jwt-secret-minimum-32-chars

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://headyme.com/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string (required)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
NEON_API_KEY=your-neon-management-api-key

# Database pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# ─── Cache / Redis ────────────────────────────────────────────────────────────
# Upstash Redis (HTTP-based, no persistent connection)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Standard Redis (if using self-hosted)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── AI Provider Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_ADMIN_KEY=sk-ant-admin-your-key
CLAUDE_API_KEY=sk-ant-your-claude-key

OPENAI_API_KEY=sk-your-openai-key
OPENAI_ORG_ID=org-your-org-id

GOOGLE_API_KEY=your-google-api-key
GEMINI_API_KEY=your-gemini-api-key

GROQ_API_KEY=gsk_your-groq-key

PERPLEXITY_API_KEY=pplx-your-key

# Hugging Face (for embeddings and models)
HF_TOKEN=hf_your-token

# Heady proprietary compute endpoints
HEADY_COMPUTE_KEY=your-heady-compute-key
HEADY_PYTHIA_KEY_HEADY=your-pythia-key
HEADY_NEXUS_KEY=your-nexus-key
HEADY_JULES_KEY=your-jules-key

# ─── Cloudflare ───────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ZONE_ID=your-zone-id

# Cloudflare Tunnel IDs
HEADY_TUNNEL_ID_HEADYME=your-tunnel-id
HEADY_TUNNEL_ID_HEADYSYSTEMS=your-tunnel-id
HEADY_TUNNEL_ID_HEADYCONNECTION=your-tunnel-id
HEADY_TUNNEL_ID_HEADYMCP=your-tunnel-id
HEADY_TUNNEL_ID_HEADYIO=your-tunnel-id
HEADY_TUNNEL_ID_HEADYBUDDY=your-tunnel-id
HEADY_TUNNEL_ID_HEADYBOT=your-tunnel-id
HEADY_TUNNEL_ID_HEADYAI=your-tunnel-id
HEADY_TUNNEL_ID_HEADYAPI=your-tunnel-id

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token

# GitHub App (for VM token service)
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=your-github-app-private-key-pem-base64
GITHUB_APP_INSTALLATION_ID=your-installation-id

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_your-notion-token
NOTION_DATABASE_ID=your-database-id

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ─── 1Password (optional secret vault) ────────────────────────────────────────
OP_SERVICE_ACCOUNT_TOKEN=ops_your-1password-sa-token

# ─── Web3 / Blockchain ────────────────────────────────────────────────────────
WEB3_PRIVATE_KEY=your-wallet-private-key
WEB3_RPC_URL=https://mainnet.infura.io/v3/your-key
INFURA_PROJECT_ID=your-infura-project-id

# ─── GCP ─────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_SA_KEY=your-base64-encoded-service-account-json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Render ───────────────────────────────────────────────────────────────────
RENDER_API_KEY=rnd_your-render-api-key

# ─── Heady Platform Configuration ─────────────────────────────────────────────
HEADY_DAILY_BUDGET=50
HEADY_CONTENT_FILTER=standard
HEADY_JSON_LIMIT=50mb

# Platform URLs (override for local dev)
HEADY_MANAGER_URL=https://headyapi.com
HEADY_EDGE_PROXY_URL=https://heady-edge-proxy.emailheadyconnection.workers.dev
HEADY_BRAIN_URL=https://headyapi.com
HEADY_CLOUDRUN_URL=https://heady-edge-gateway-609590223909.us-central1.run.app

# ─── Pinecone (optional vector store) ────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=heady-vectors

# ─── Embedding Configuration ──────────────────────────────────────────────────
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_URL=http://127.0.0.1:11434/api/embeddings
EMBEDDING_LOCAL_MODEL=nomic-embed-text

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_BATTLE_MODE=true
FEATURE_ARENA_MODE=true
FEATURE_HEADYCOIN=true
FEATURE_VOICE_RELAY=true
FEATURE_MCP_SERVER=true
FEATURE_SELF_HEALING=true
